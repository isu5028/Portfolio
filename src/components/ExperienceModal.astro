---
import type { Experience } from '../data/experiences';

export interface Props {
  experiences: Experience[];
}

const { experiences } = Astro.props;
---

<div
  id="exp-modal"
  class="fixed inset-0 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-all duration-200"
>
  <!-- Backdrop -->
  <div id="exp-modal-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-sm cursor-pointer"></div>

  <!-- Modal Content -->
  <div class="relative z-10 w-full max-w-3xl max-h-[90vh] overflow-y-auto
    bg-bg-primary pixel-box-gold">

    <!-- Header bar -->
    <div class="flex items-center justify-between px-5 py-3 bg-retro-gold/10 border-b-4 border-retro-gold">
      <span class="font-pixel text-retro-gold text-sm tracking-widest">*** EXPERIENCE INFO ***</span>
      <button
        id="exp-modal-close"
        class="font-pixel text-retro-cream hover:text-retro-gold transition-colors cursor-pointer text-sm"
        aria-label="閉じる"
      >
        [X] CLOSE
      </button>
    </div>

    <div class="p-6">
      <!-- Role + Title -->
      <div class="mb-5">
        <div class="flex items-center justify-between mb-2">
          <span id="exp-modal-category" class="font-pixel text-retro-cream/40 text-xs tracking-widest uppercase"></span>
          <span id="exp-modal-period" class="font-pixel text-retro-gold text-xs"></span>
        </div>
        <div id="exp-modal-org" class="font-pixel text-retro-orange text-sm mb-1"></div>
        <h2 id="exp-modal-title" class="font-pixel text-retro-cream text-2xl leading-snug mb-3"
          style="text-shadow: 0 0 8px #f0b832;"></h2>
      </div>

      <div class="retro-divider-gold"></div>

      <!-- Screenshot space -->
      <div id="exp-modal-screenshots"
        class="flex gap-3 overflow-x-auto pb-2 mb-5"
        style="scrollbar-color: #f0b832 #1c0f0f;">
      </div>

      <!-- YouTube embeds -->
      <div id="exp-modal-youtube" class="mb-5 space-y-3"></div>

      <!-- Details -->
      <p id="exp-modal-details"
        class="font-retro text-retro-cream/80 text-xl leading-relaxed mb-5 whitespace-pre-wrap"></p>

      <!-- Note links -->
      <div id="exp-modal-notes" class="mb-5 space-y-3"></div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-5" id="exp-modal-tags"></div>

      <!-- Divider -->
      <div class="retro-divider"></div>

      <!-- Link (Optional) -->
      <div id="exp-modal-link-wrapper" class="hidden mt-4">
        <a
          id="exp-modal-link"
          href="#"
          target="_blank"
          rel="noopener noreferrer"
          class="pixel-btn-gold inline-block"
        >
          <span id="exp-modal-link-label">▶ 詳細を見る</span>
        </a>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ experiences }}>
  const EXPS = experiences;

  const modal      = document.getElementById('exp-modal');
  const backdrop   = document.getElementById('exp-modal-backdrop');
  const closeBtn   = document.getElementById('exp-modal-close');
  const elCategory   = document.getElementById('exp-modal-category');
  const elPeriod     = document.getElementById('exp-modal-period');
  const elOrg        = document.getElementById('exp-modal-org');
  const elTitle      = document.getElementById('exp-modal-title');
  const elDetails    = document.getElementById('exp-modal-details');
  const elShots      = document.getElementById('exp-modal-screenshots');
  const elYt         = document.getElementById('exp-modal-youtube');
  const elNotes      = document.getElementById('exp-modal-notes');
  const elTags       = document.getElementById('exp-modal-tags');
  const elLinkWrap   = document.getElementById('exp-modal-link-wrapper');
  const elLink       = document.getElementById('exp-modal-link');
  const elLinkLbl    = document.getElementById('exp-modal-link-label');

  // YouTube URL → 動画ID を抽出し、URLを除去した本文も返す
  function extractYouTube(text) {
    const re = /https?:\/\/(?:youtu\.be\/|(?:www\.)?youtube\.com\/watch\?v=)([\w-]+)[^\s]*/g;
    const ids = [];
    if (!text) return { ids, clean: '' };
    const clean = text.replace(re, (_, id) => { ids.push(id); return ''; }).trim();
    return { ids, clean };
  }

  function extractNotes(text) {
    const urls = [];
    if (!text) return { urls, clean: '' };
    const re = /https?:\/\/note\.com\/[\w-]+\/n\/[\w-]+(?:\?[^\s]*)?/g;
    const clean = text.replace(re, (url) => { urls.push(url); return ''; }).trim();
    return { urls, clean };
  }

  function openExpModal(expId) {
    const exp = EXPS.find(e => e.id === expId);
    if (!exp) return;

    elCategory.textContent = exp.category;
    elPeriod.textContent   = exp.period;
    elOrg.textContent      = exp.organization;
    elTitle.textContent    = exp.title;

    const { ids: ytIds, clean: detailsNoYt } = extractYouTube(exp.details);
    const { urls: noteUrls, clean: detailsClean } = extractNotes(detailsNoYt);
    elDetails.textContent = detailsClean;

    // YouTube 埋め込み
    if (elYt) {
      elYt.innerHTML = '';
      ytIds.forEach(id => {
        const wrapper = document.createElement('div');
        wrapper.className = 'relative w-full border-2 border-retro-gold/40';
        wrapper.style.paddingTop = '56.25%';
        const iframe = document.createElement('iframe');
        iframe.src = `https://www.youtube.com/embed/${id}`;
        iframe.className = 'absolute inset-0 w-full h-full';
        iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
        iframe.setAttribute('allowfullscreen', '');
        iframe.setAttribute('loading', 'lazy');
        wrapper.appendChild(iframe);
        elYt.appendChild(wrapper);
      });
    }

    // Note リンクカード
    if (elNotes) {
      elNotes.innerHTML = '';
      noteUrls.forEach(url => {
        const card = document.createElement('a');
        card.href = url;
        card.target = '_blank';
        card.rel = 'noopener noreferrer';
        card.className = 'flex items-center gap-4 p-4 border-2 border-retro-gold/30 bg-bg-secondary hover:bg-retro-gold/10 transition-colors group';
        card.innerHTML = `
          <div class="flex-shrink-0 w-12 h-12 bg-white flex items-center justify-center rounded">
             <span class="text-black font-bold text-xl">n</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-pixel text-retro-gold text-xs mb-1">note.com で記事を読む</div>
            <div class="font-retro text-retro-cream/80 text-sm truncate underline decoration-retro-gold/50 group-hover:text-retro-gold">${url}</div>
          </div>
          <div class="text-retro-gold/40 font-pixel text-xs font-bold">▶ VIEW</div>
        `;
        elNotes.appendChild(card);
      });
    }

    // Screenshots — プリロードして最小サイズに合わせる
    if (elShots) {
      elShots.innerHTML = '';
      const isImg = exp.thumbnail && (exp.thumbnail.startsWith('/') || exp.thumbnail.includes('.'));
      const ssImgs = isImg ? [{ src: exp.thumbnail, alt: exp.title }] : [];
      
      if (ssImgs.length) {
        elShots.classList.remove('hidden');
        const imgEls = ssImgs.map(ss => {
          const wrap = document.createElement('div');
          wrap.className = 'relative flex-shrink-0 overflow-hidden border-2 border-retro-gold/40 bg-bg-secondary flex items-center justify-center';
          wrap.style.height = '220px';
          wrap.style.width  = 'auto';
          
          // ローディング表示
          const loading = document.createElement('div');
          loading.className = 'absolute inset-0 flex items-center justify-center z-20 bg-bg-secondary';
          loading.innerHTML = '<span class="font-pixel text-retro-gold animate-pulse">NOW LOADING...</span>';
          wrap.appendChild(loading);

          const img = document.createElement('img');
          img.src = ss.src;
          img.alt = ss.alt;
          img.className = 'h-full w-auto block';
          wrap.appendChild(img);
          elShots.appendChild(wrap);
          return { wrap, loading };
        });
        Promise.all(ssImgs.map(ss => new Promise(resolve => {
          const probe = new Image();
          probe.onload  = () => resolve({ w: probe.naturalWidth, h: probe.naturalHeight });
          probe.onerror = () => resolve({ w: 800, h: 450 });
          probe.src = ss.src;
        }))).then(dims => {
          const containerW = elShots.offsetWidth || 560;
          const targetH = Math.min(
            480,
            Math.min(...dims.map(d => Math.round(containerW * d.h / d.w)))
          );
          imgEls.forEach(({ wrap, loading }, i) => {
            const d = dims[i];
            const exactW = Math.round(targetH * d.w / d.h);
            wrap.style.height = targetH + 'px';
            wrap.style.width  = Math.min(exactW, containerW) + 'px';
            
            // ローディングを消す
            if (loading) {
              loading.style.opacity = '0';
              loading.style.transition = 'opacity 0.3s';
              setTimeout(() => loading.remove(), 300);
            }
          });
        });
      } else {
        elShots.classList.add('hidden');
      }
    }

    // Tags
    elTags.innerHTML = '';
    exp.tags.forEach(t => {
      const s = document.createElement('span');
      s.className = 'font-pixel bg-bg-primary px-3 py-0.5 text-xs text-retro-gold border-2 border-retro-gold/30';
      s.textContent = t;
      elTags.appendChild(s);
    });

    // Link
    if (exp.link) {
      elLinkWrap.classList.remove('hidden');
      elLink.href = exp.link;
      if (elLinkLbl) elLinkLbl.textContent = '▶ ' + (exp.linkLabel || '詳細を見る');
    } else {
      elLinkWrap.classList.add('hidden');
    }

    // Show
    modal.classList.remove('pointer-events-none', 'opacity-0');
    document.body.style.overflow = 'hidden';
  }

  function closeExpModal() {
    modal.classList.add('pointer-events-none', 'opacity-0');
    document.body.style.overflow = '';
  }

  // Listeners
  document.addEventListener('click', (e) => {
    const card = e.target.closest('.exp-card');
    if (card) {
      const id = card.getAttribute('data-exp-id');
      openExpModal(id);
    }
  });

  closeBtn.addEventListener('click', closeExpModal);
  backdrop.addEventListener('click', closeExpModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeExpModal();
  });
</script>

---
import type { Game } from '../data/games';

export interface Props {
  games: Game[];
}

const { games } = Astro.props;
---

<div
  id="game-modal"
  class="fixed inset-0 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-all duration-200"
>
  <!-- Backdrop -->
  <div id="modal-backdrop" class="absolute inset-0 bg-black/80 backdrop-blur-sm cursor-pointer"></div>

  <!-- Modal Content -->
  <div class="relative z-10 w-full max-w-6xl max-h-[90vh] overflow-y-auto
    bg-bg-primary pixel-box-gold">

    <!-- Header bar -->
    <div class="flex items-center justify-between px-5 py-3 bg-retro-gold/10 border-b-4 border-retro-gold">
      <span class="font-pixel text-retro-gold text-sm tracking-widest">*** GAME INFO ***</span>
      <button
        id="modal-close"
        class="font-pixel text-retro-cream hover:text-retro-gold transition-colors cursor-pointer text-sm"
        aria-label="閉じる"
      >
        [X] CLOSE
      </button>
    </div>

    <div class="p-5 lg:p-6">
      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(340px,0.85fr)] lg:items-start">
        <div class="min-w-0 lg:sticky lg:top-6">
          <!-- Screenshots carousel -->
          <div id="modal-screenshots" class="mb-5 lg:mb-4"></div>

          <!-- YouTube embeds -->
          <div id="modal-youtube" class="mb-5 lg:mb-0 space-y-3"></div>
        </div>

        <div class="min-w-0">
      <!-- Genre + Title -->
      <div class="mb-5">
        <div id="modal-genre" class="font-pixel text-retro-cream/40 text-sm mb-2 tracking-widest"></div>
        <h2 id="modal-title" class="font-pixel text-retro-gold text-2xl leading-snug mb-3"
          style="text-shadow: 0 0 8px #f0b832;"></h2>
        <div class="flex flex-wrap gap-2" id="modal-tools"></div>
      </div>

      <div class="retro-divider-gold"></div>

      <!-- Description -->
      <p id="modal-description" class="font-retro text-retro-cream/80 text-lg xl:text-xl leading-relaxed mb-5 whitespace-pre-wrap"></p>

      <!-- Note links -->
      <div id="modal-notes" class="mb-5 space-y-3"></div>

      <div class="retro-divider"></div>

      <!-- Link -->
      <div id="modal-link-wrapper" class="hidden mt-4 flex flex-wrap gap-3"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ games }}>
  const GAMES = games;

  const modal        = document.getElementById('game-modal');
  const backdrop     = document.getElementById('modal-backdrop');
  const closeBtn     = document.getElementById('modal-close');
  const modalTitle   = document.getElementById('modal-title');
  const modalGenre   = document.getElementById('modal-genre');
  const modalTools   = document.getElementById('modal-tools');
  const modalShots   = document.getElementById('modal-screenshots');
  const modalYt      = document.getElementById('modal-youtube');
  const modalNotes   = document.getElementById('modal-notes');
  const modalDesc    = document.getElementById('modal-description');
  const modalLinkWrap= document.getElementById('modal-link-wrapper');

  const toolColorMap = {
    cyan:   'border-2 border-retro-orange text-retro-orange',
    purple: 'border-2 border-retro-red    text-retro-red',
    pink:   'border-2 border-retro-red    text-retro-red',
    green:  'border-2 border-retro-gold   text-retro-gold',
    yellow: 'border-2 border-retro-gold   text-retro-gold',
  };

  // YouTube URL → 動画ID を抽出し、URLを除去した本文も返す
  function extractYouTube(text) {
    const re = /https?:\/\/(?:youtu\.be\/|(?:www\.)?youtube\.com\/watch\?v=)([\w-]+)[^\s]*/g;
    const ids = [];
    const clean = text.replace(re, (_, id) => { ids.push(id); return ''; }).trim();
    return { ids, clean };
  }

  function extractNotes(text) {
    const urls = [];
    const re = /https?:\/\/note\.com\/[\w-]+\/n\/[\w-]+(?:\?[^\s]*)?/g;
    const clean = text.replace(re, (url) => { urls.push(url); return ''; }).trim();
    return { urls, clean };
  }

  function openModal(gameId) {
    const game = GAMES.find(g => g.id === gameId);
    if (!game) return;

    modalTitle.textContent = game.title;
    modalGenre.textContent = '// ' + game.genre;

    // Tools
    modalTools.innerHTML = '';
    const tc = toolColorMap[game.accentColor] || toolColorMap.purple;
    game.tools.forEach(t => {
      const s = document.createElement('span');
      s.className = `font-pixel bg-bg-primary px-3 py-1 text-sm ${tc}`;
      s.textContent = t;
      modalTools.appendChild(s);
    });
    const yr = document.createElement('span');
    yr.className = 'font-pixel bg-bg-primary px-3 py-1 text-sm border-2 border-retro-cream/20 text-retro-cream/40';
    yr.textContent = game.year;
    modalTools.appendChild(yr);

    // Screenshots — カルーセル
    modalShots.innerHTML = '';
    
    // 有効な画像パスのみを抽出
    const rawImgs = game.screenshots.length ? game.screenshots : [{ src: game.thumbnail, alt: game.title }];
    const imgs = rawImgs.filter(img => img.src && (img.src.startsWith('/') || img.src.includes('.')));
    
    if (imgs.length === 0) {
      modalShots.classList.add('hidden');
    } else {
      modalShots.classList.remove('hidden');
      let currentIdx = 0;

    // カルーセル外整布 (relative for button overlay)
    const carouselWrap = document.createElement('div');
    carouselWrap.style.position = 'relative';
    modalShots.appendChild(carouselWrap);

    // 画像トラック
    const track = document.createElement('div');
    track.className = 'relative overflow-hidden border-2 border-retro-orange/40 bg-bg-secondary flex items-center justify-center';
    track.style.height = '260px'; // 仮の高さ
    carouselWrap.appendChild(track);

    // ローディング表示
    const loading = document.createElement('div');
    loading.className = 'absolute inset-0 flex items-center justify-center z-20 bg-bg-secondary';
    loading.innerHTML = '<span class="font-pixel text-retro-orange animate-pulse">NOW LOADING...</span>';
    track.appendChild(loading);

    // 画像要素を生成（最初のみ表示）
    const imgEls = imgs.map((ss, i) => {
      const img = document.createElement('img');
      img.src = ss.src;
      img.alt = ss.alt;
      img.style.maxWidth  = '100%';
      img.style.maxHeight = '100%';
      img.style.width     = 'auto';
      img.style.height    = 'auto';
      img.style.display   = i === 0 ? 'block' : 'none';
      track.appendChild(img);
      return img;
    });

    // カウンター
    const counter = document.createElement('div');
    counter.className = 'font-pixel text-retro-cream/40 text-xs text-center mt-2';
    counter.textContent = imgs.length > 1 ? `1 / ${imgs.length}` : '';
    modalShots.appendChild(counter);

    function carouselGoTo(idx) {
      imgEls[currentIdx].style.display = 'none';
      currentIdx = ((idx % imgs.length) + imgs.length) % imgs.length;
      imgEls[currentIdx].style.display = 'block';
      counter.textContent = imgs.length > 1 ? `${currentIdx + 1} / ${imgs.length}` : '';
    }

    // 複数画像のときのみ ◄ ► ボタンを表示
    if (imgs.length > 1) {
      const mkCarouselBtn = (symbol, side) => {
        const btn = document.createElement('button');
        btn.innerHTML = symbol;
        btn.type = 'button';
        btn.className = 'absolute top-0 bottom-0 z-10 px-6 font-pixel text-retro-cream/70 hover:text-retro-gold hover:bg-black/40 transition-colors duration-75 text-4xl select-none';
        btn.style[side] = '0';
        carouselWrap.appendChild(btn);
        return btn;
      };
      const prevBtn = mkCarouselBtn('◄', 'left');
      const nextBtn = mkCarouselBtn('►', 'right');
      prevBtn.addEventListener('click', () => carouselGoTo(currentIdx - 1));
      nextBtn.addEventListener('click', () => carouselGoTo(currentIdx + 1));
    }

    // 全画像をプリロードし、最小アスペクト比からトラックの高さを決定
    Promise.all(imgs.map(ss => new Promise(resolve => {
      const probe = new Image();
      probe.onload  = () => resolve({ w: probe.naturalWidth, h: probe.naturalHeight });
      probe.onerror = () => resolve({ w: 800, h: 450 });
      probe.src = ss.src;
    }))).then(dims => {
      const containerW = track.offsetWidth || 600;
      const maxMediaH = window.matchMedia('(min-width: 1024px)').matches ? 340 : 420;
      const targetH = Math.min(
        maxMediaH,
        Math.min(...dims.map(d => Math.round(containerW * d.h / d.w)))
      );
      track.style.height = targetH + 'px';
      imgEls.forEach(img => { img.style.maxHeight = targetH + 'px'; });
      
      // ローディングを消す
      loading.style.opacity = '0';
      loading.style.transition = 'opacity 0.3s';
      setTimeout(() => loading.remove(), 300);
    });
    } // end if imgs.length > 0

    const { ids: ytIds, clean: descNoYt } = extractYouTube(game.description);
    const { urls: noteUrls, clean: descClean } = extractNotes(descNoYt);
    modalDesc.textContent = descClean;

    // YouTube 埋め込み
    modalYt.innerHTML = '';
    ytIds.forEach(id => {
      const wrapper = document.createElement('div');
      wrapper.className = 'relative w-full border-2 border-retro-orange/40 bg-bg-secondary';
      wrapper.style.paddingTop = '56.25%'; // 16:9
      const iframe = document.createElement('iframe');
      iframe.src = `https://www.youtube.com/embed/${id}`;
      iframe.className = 'absolute inset-0 w-full h-full';
      iframe.setAttribute('allow', 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture');
      iframe.setAttribute('allowfullscreen', '');
      iframe.setAttribute('loading', 'lazy');
      wrapper.appendChild(iframe);
      modalYt.appendChild(wrapper);
    });

    // Note リンクカード
    modalNotes.innerHTML = '';
    noteUrls.forEach(url => {
      const card = document.createElement('a');
      card.href = url;
      card.target = '_blank';
      card.rel = 'noopener noreferrer';
      card.className = 'flex items-center gap-4 p-4 border-2 border-retro-gold/30 bg-bg-secondary hover:bg-retro-gold/10 transition-colors group';
      card.innerHTML = `
        <div class="flex-shrink-0 w-12 h-12 bg-white flex items-center justify-center rounded">
           <span class="text-black font-bold text-xl">n</span>
        </div>
        <div class="flex-1 min-w-0">
          <div class="font-pixel text-retro-gold text-xs mb-1">note.com で記事を読む</div>
          <div class="font-retro text-retro-cream/80 text-sm truncate underline decoration-retro-gold/50 group-hover:text-retro-gold">${url}</div>
        </div>
        <div class="text-retro-gold/40 font-pixel text-xs font-bold">▶ VIEW</div>
      `;
      modalNotes.appendChild(card);
    });

    const gameLinks = [
      ...(game.link ? [{ url: game.link, label: game.linkLabel || '遊んでみる', className: 'pixel-btn-orange' }] : []),
      ...(game.links || []).map(link => ({ ...link, className: 'pixel-btn-orange' })),
      ...(game.gitLink ? [{ url: game.gitLink, label: 'Git', className: 'pixel-btn-white' }] : []),
    ];

    modalLinkWrap.innerHTML = '';
    if (gameLinks.length) {
      modalLinkWrap.classList.remove('hidden');
      gameLinks.forEach(({ url, label, className }) => {
        const link = document.createElement('a');
        link.href = url;
        link.target = '_blank';
        link.rel = 'noopener noreferrer';
        link.className = className + ' inline-block';
        link.textContent = '▶ ' + label;
        modalLinkWrap.appendChild(link);
      });
    } else {
      modalLinkWrap.classList.add('hidden');
    }

    // Show modal
    modal.classList.remove('pointer-events-none', 'opacity-0');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.add('pointer-events-none', 'opacity-0');
    document.body.style.overflow = '';
  }

  // Event Listeners
  document.addEventListener('click', (e) => {
    const card = e.target.closest('.game-card');
    if (card) {
      const id = card.getAttribute('data-game-id');
      openModal(id);
    }
  });

  closeBtn.addEventListener('click', closeModal);
  backdrop.addEventListener('click', closeModal);

  // ESC key to close
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>

---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import GameCard from '../components/GameCard.astro';
import GameModal from '../components/GameModal.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import ExperienceModal from '../components/ExperienceModal.astro';
import { games } from '../data/games';
import { experiences } from '../data/experiences';

const skills = [
  { name: 'C#',         detail: 'since 2019' },
  { name: 'HLSL',       detail: 'shader programming / NPR research' },
  { name: 'C++',        detail: 'ray tracing / graphics programming' },
  { name: 'Unity',      detail: 'since 2019  /  20+ titles' },
  { name: 'Godot',      detail: '1 title released' },
  { name: 'RE ENGINE',  detail: 'CAPCOM GAMES COMPETITION entry (2025)' },
  { name: 'Aseprite',   detail: 'since 2022' },
];

const socials = [
  { label: 'GitHub',      href: 'https://github.com/isu5028',   id: 'link-github'  },
  { label: 'itch.io',     href: 'https://isu502884.itch.io/',   id: 'link-itchio'  },
  { label: 'Twitter / X', href: 'https://x.com/isu502884',      id: 'link-twitter' },
];
---

<Layout title="isu / 八木寛季 | Game Developer Portfolio">
  <Navbar />

  <!-- ========== HERO ========== -->
  <section id="top" class="relative min-h-screen flex items-center justify-center px-6 overflow-hidden">
    <!-- Warm dark bg pattern -->
    <div class="absolute inset-0 pointer-events-none opacity-[0.06]"
      style="background-image: linear-gradient(#b74646 1px, transparent 1px), linear-gradient(90deg, #b74646 1px, transparent 1px); background-size: 48px 48px;">
    </div>
    <!-- Top-left retro frame -->
    <div class="absolute top-24 left-8 font-pixel text-retro-red/25 leading-relaxed text-sm hidden lg:block">
      ╔══════════════╗<br/>
      ║  PLAYER  1   ║<br/>
      ║  SCORE  000  ║<br/>
      ╚══════════════╝
    </div>
    <!-- Top-right retro frame -->
    <div class="absolute top-24 right-8 font-pixel text-retro-red/25 leading-relaxed text-sm hidden lg:block">
      ╔══════════════╗<br/>
      ║  HI-SCORE    ║<br/>
      ║   ISU502     ║<br/>
      ╚══════════════╝
    </div>

    <div class="relative text-center max-w-3xl mx-auto">
      <!-- Name -->
      <h1 class="font-pixel leading-snug mb-3 animate-glitch"
        style="font-size:clamp(2rem,6vw,3.5rem); color:#f5e8d3; text-shadow: 3px 3px 0 #b74646, 0 0 16px #b74646aa;">
        八木 寛季
      </h1>
      <p class="font-pixel text-retro-red text-lg mb-10 tracking-[0.3em]">
        [ isu ]
      </p>

      <!-- Tagline -->
      <p class="font-retro text-retro-cream/70 text-2xl mb-12 leading-relaxed">
        &gt; GAME DEVELOPER_
      </p>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="#works"   id="hero-works-btn"   class="pixel-btn-gold">▶ VIEW WORKS</a>
        <a href="#contact" id="hero-contact-btn" class="pixel-btn-red">✉ CONTACT</a>
      </div>

      <!-- Scroll hint -->
      <div class="mt-16 font-pixel text-retro-cream/25 text-sm animate-blink">
        ▼ SCROLL DOWN ▼
      </div>
    </div>
  </section>

  <!-- ========== ABOUT ========== -->
  <section id="about" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10">
        <p class="section-label text-retro-red/60 mb-2">// STAGE 01</p>
        <h2 class="font-pixel text-retro-cream text-2xl" style="text-shadow: 2px 2px 0 #b74646;">ABOUT ME</h2>
        <div class="retro-divider"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-10 items-start">
        <!-- Bio -->
        <div>
          <!-- Player card -->
          <div class="pixel-box-red p-5 mb-6 bg-bg-secondary">
            <div class="font-pixel text-retro-red text-sm mb-3 tracking-widest">PLAYER DATA</div>
            <div class="font-retro text-retro-cream text-xl leading-loose space-y-1">
              <p>&gt; NAME  : 八木 寛季（isu）</p>
              <p>&gt; CLASS : Game Developer</p>
              <p>&gt; TOOLS : Unity / Godot / C# / HLSL / C++</p>
              <p>&gt; ART   : Aseprite / ClipStudio</p>
            </div>
          </div>
          <div class="font-retro text-retro-cream/70 text-xl leading-relaxed space-y-3">
            <p>
              7年間のゲーム開発で20本以上のゲームを公開。
            </p>
            <p>
              大学では、非写実的レンダリング研究からレイトレーシング実装まで、
              レンダリング技術を実践と理論の両面から追求しています。
            </p>
            <p>
              BitSummit Game Jam 2023 東京組グランプリ受賞。
            </p>
            <p>
              株式会社Live2D にてSDK開発に2.5年従事。
            </p>
          </div>
          <!-- Socials -->
          <div class="flex flex-wrap gap-3 mt-6">
            {socials.map(s => (
              <a href={s.href} id={s.id} target="_blank" rel="noopener noreferrer"
                class="font-pixel text-retro-cream border-2 border-retro-red/50 px-3 py-2 text-sm
                  hover:bg-retro-red hover:border-retro-red hover:text-bg-primary transition-colors duration-100">
                {s.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Skills -->
        <div class="pixel-box-orange p-5 bg-bg-secondary">
          <div class="font-pixel text-retro-orange text-sm mb-5 tracking-widest">SKILL STATS</div>
          <div class="space-y-3">
            {skills.map(skill => (
              <div class="border-l-4 border-retro-orange/50 pl-4 py-1 hover:border-retro-orange transition-colors duration-100">
                <div class="font-pixel text-retro-cream text-sm mb-0.5">{skill.name}</div>
                <div class="font-retro text-retro-orange/80 text-lg">{skill.detail}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== EXPERIENCE ========== -->
  <section id="experience" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10">
        <p class="section-label text-retro-red/60 mb-2">// STAGE 02</p>
        <h2 class="font-pixel text-retro-cream text-2xl" style="text-shadow: 2px 2px 0 #b74646;">EXPERIENCE</h2>
        <div class="retro-divider"></div>
        <p class="font-retro text-retro-cream/40 text-xl">&gt; SELECT AND PRESS START</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6" id="exp-grid">
        {experiences.map((exp, i) => (
          <ExperienceCard exp={exp} index={i} />
        ))}
      </div>
    </div>
  </section>

  <!-- ========== WORKS ========== -->
  <section id="works" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="mb-10">
        <p class="section-label text-retro-orange/60 mb-2">// STAGE 03</p>
        <h2 class="font-pixel text-retro-cream text-2xl" style="text-shadow: 2px 2px 0 #e0784a;">GAME SELECT</h2>
        <div class="retro-divider-orange"></div>
        <p class="font-retro text-retro-cream/40 text-xl">&gt; SELECT YOUR GAME AND PRESS START</p>
      </div>

      <!-- 最初の8件：常時表示 -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-5 md:gap-6" id="games-grid">
        {games.slice(0, 8).map((game, i) => (
          <GameCard game={game} index={i} />
        ))}
      </div>

      <!-- 9件目以降：折り畳み -->
      {games.length > 8 && (
        <>
          <div
            id="games-extra"
            class="grid grid-cols-2 sm:grid-cols-4 gap-5 md:gap-6 mt-5 md:mt-6 overflow-hidden"
            style="max-height: 0; opacity: 0; transition: max-height 0.5s ease, opacity 0.4s ease;"
          >
            {games.slice(8).map((game, i) => (
              <GameCard game={game} index={i + 8} />
            ))}
          </div>

          <div class="mt-8 text-center">
            <button
              id="games-toggle-btn"
              class="pixel-btn-orange font-pixel"
              aria-expanded="false"
            >
              ▼ MORE GAMES ({games.length - 8})
            </button>
          </div>
        </>
      )}
    </div>
  </section>

  <!-- ========== CONTACT ========== -->
  <section id="contact" class="py-24 px-6">
    <div class="max-w-2xl mx-auto">
      <div class="mb-10">
        <p class="section-label text-retro-gold/60 mb-2">// STAGE 04</p>
        <h2 class="font-pixel text-retro-cream text-2xl" style="text-shadow: 2px 2px 0 #f0b832;">CONTACT</h2>
        <div class="retro-divider-gold"></div>
      </div>

      <div class="pixel-box-gold p-6 bg-bg-secondary">
        <div class="font-pixel text-retro-gold text-sm mb-6 animate-blink tracking-widest">
          *** SEND MESSAGE ***
        </div>

        <div class="space-y-4">
          <!-- Email -->
          <div class="flex items-center gap-4 border-2 border-retro-red/20 p-4 bg-bg-primary
            hover:bg-retro-red/10 transition-colors">
            <span class="font-pixel text-retro-red/50 text-lg">&gt;&gt;</span>
            <div>
              <div class="font-pixel text-retro-cream/40 text-sm mb-1">EMAIL</div>
              <a href="mailto:isu502884@gmail.com"
                id="contact-email"
                class="font-retro text-retro-orange hover:text-retro-gold transition-colors text-2xl">
                isu502884@gmail.com
              </a>
            </div>
          </div>

          <!-- Social grid -->
          <div class="grid grid-cols-3 gap-3">
            {socials.map(s => (
              <a href={s.href} target="_blank" rel="noopener noreferrer"
                class="font-pixel text-center py-3 text-sm border-2 border-retro-cream/20 text-retro-cream/50
                  hover:border-retro-red hover:text-retro-cream hover:bg-retro-red/10
                  transition-colors duration-100">
                {s.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-6 px-6 border-t-4 border-retro-red/20">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="font-pixel text-retro-cream/25 text-sm">&copy; 2025 ISU / 八木寛季</p>
      <p class="font-pixel text-retro-cream/15 text-sm">BUILT WITH ASTRO + TAILWIND CSS</p>
    </div>
  </footer>

  <!-- フローティング HIDE GAMES ボタン（展開中かつセクションが見えている間だけ表示） -->
  <div
    id="games-float-wrap"
    class="fixed bottom-6 left-1/2 z-40 pointer-events-none"
    style="transform: translateX(-50%); opacity:0; transition: opacity 0.3s;"
  >
    <button
      id="games-float-btn"
      class="pointer-events-auto font-pixel text-sm px-6 py-3 bg-bg-primary text-retro-red border-2 border-retro-red hover:bg-retro-red hover:text-bg-primary transition-colors duration-100 shadow-xl"
      style="box-shadow: 4px 4px 0 #7a3030;"
    >
      ▲ HIDE GAMES
    </button>
  </div>

  <GameModal games={games} />
  <ExperienceModal experiences={experiences} />
</Layout>

<script is:inline>
  // Skill bars (unused but kept for safety)
  const bars = document.querySelectorAll('.skill-bar');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.width = e.target.getAttribute('data-level') + '%';
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  bars.forEach(b => obs.observe(b));

  // Games fold/unfold toggle + floating HIDE button
  const gamesExtra    = document.getElementById('games-extra');
  const gamesToggle   = document.getElementById('games-toggle-btn');
  const gamesSection  = document.getElementById('works');
  const floatWrap     = document.getElementById('games-float-wrap');
  const floatBtn      = document.getElementById('games-float-btn');

  if (gamesExtra && gamesToggle) {
    let open = false;

    // 初期状態で実際の高さを計測するために一時展開
    gamesExtra.style.maxHeight = 'none';
    const fullHeight = gamesExtra.scrollHeight + 'px';
    gamesExtra.style.maxHeight = '0';

    // GAME SELECT セクションの可視状態を監視
    let sectionVisible = false;
    const sectionObs = new IntersectionObserver(entries => {
      sectionVisible = entries[0].isIntersecting;
      updateFloat();
    }, { threshold: 0.05 });
    if (gamesSection) sectionObs.observe(gamesSection);

    function updateFloat() {
      const show = open && sectionVisible;
      if (floatWrap) {
        floatWrap.style.opacity         = show ? '1' : '0';
        floatWrap.style.pointerEvents   = show ? 'auto' : 'none';
      }
    }

    function setOpen(nextOpen) {
      open = nextOpen;
      if (open) {
        gamesExtra.style.maxHeight = fullHeight;
        gamesExtra.style.opacity   = '1';
        gamesToggle.textContent    = '▲ HIDE GAMES';
        gamesToggle.setAttribute('aria-expanded', 'true');
      } else {
        gamesExtra.style.maxHeight = '0';
        gamesExtra.style.opacity   = '0';
        gamesToggle.textContent    = '▼ MORE GAMES';
        gamesToggle.setAttribute('aria-expanded', 'false');
      }
      updateFloat();
    }

    gamesToggle.addEventListener('click', () => setOpen(!open));
    if (floatBtn) floatBtn.addEventListener('click', () => setOpen(false));
  }
</script>
